# CUDA compiler
NVCC = nvcc

# Target executable name
TARGET = test.exe

# Object files
OBJ = test.obj profiler.obj


# Default build rule
all: $(TARGET)

# Link the object files into an executable
$(TARGET): $(OBJ)
	$(NVCC) -o $(TARGET) $(OBJ)

# Compile CUDA source files into object files
test.obj: test.cu
	$(NVCC) -c test.cu -o test.obj

profiler.obj: profiler.cu
	$(NVCC) -c profiler.cu -o profiler.obj

# Clean up generated files
clean:
	del /Q $(TARGET) *.obj
